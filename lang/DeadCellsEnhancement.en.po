msgid "Speed Instinct"
msgstr "Speed Instinct"

msgid "Only while this mutation is selected, weapon attack speed increases with active Boss Cells: 0 cells +0%, 1 cell +20%, 2 cells +30%, 3-4 cells +40%, 5 cells +50%."
msgstr "Only while this mutation is selected, weapon attack speed increases with active Boss Cells: 0 cells +0%, 1 cell +20%, 2 cells +30%, 3-4 cells +40%, 5 cells +50%."

msgid "The harsher the island becomes, the faster your hands remember how to survive."
msgstr "The harsher the island becomes, the faster your hands remember how to survive."

msgid "Cell Vitality"
msgstr "Cell Vitality"

msgid "Only while this mutation is selected, each enemy killed increases maximum health by active Boss Cells x 100. At 0 cells, it grants no bonus."
msgstr "Only while this mutation is selected, each enemy killed increases maximum health by active Boss Cells x 100. At 0 cells, it grants no bonus."

msgid "Reforge to random Legendary quality"
msgstr "Reforge to random Legendary quality"

msgid "Alchemic Forge"
msgstr "Alchemic Forge"

msgid "Unlocks the \"Reforge to random Legendary quality\" option at the underground forge, where you can spend gold to reforge an item into a random Legendary."
msgstr "Unlocks the \"Reforge to random Legendary quality\" option at the underground forge, where you can spend gold to reforge an item into a random Legendary."
